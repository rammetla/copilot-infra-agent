{
  "name": "Azure Infrastructure Agent",
  "url": "https://github.com/rammetla/copilot-infra-agent",
  "hook_attributes": {},
  "public": true,
  "description": "A GitHub Copilot custom agent for provisioning and managing Azure infrastructure using Terraform and GitHub Actions",
  "installations_count": 0,
  "permissions": {
    "contents": "read",
    "workflows": "read",
    "actions": "write",
    "pull_requests": "write",
    "statuses": "read"
  },
  "events": [
    "workflow_run",
    "pull_request"
  ],
  "default_events": [
    "workflow_run"
  ],
  "display_target": "PUBLIC",
  "redirect_url": "https://github.com/rammetla/copilot-infra-agent",
  "request_oauth_on_install": false,
  "setup_on_update": false,
  "single_file_path": "",
  "web_flow_enabled": true
}
